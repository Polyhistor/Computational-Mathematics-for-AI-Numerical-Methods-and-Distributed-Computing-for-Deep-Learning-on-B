# LaTeX gitignore
# Ignore intermediate and output files generated by LaTeX.

# Logs and intermediate files
*.aux
*.log
*.out
*.fls
*.fdb_latexmk
*.synctex.gz
*.nav
*.snm
*.toc
*.vrb
*.lof
*.lot
*.bbl
*.blg
*.run.xml
*.bcf

# Generated images
*.eps
# *.pdf  # Commented out to allow PDF files
*.svg
*.dvi

# Exception for main.pdf
!main.pdf

# Temporary files
*~
*.backup
*.bak
*.swp

# Compiled files
*.synctex(busy)
*.synctex.gz(busy)

# Specific editor or tool files
# Latexmk specific
latexmkrc

# VS Code LaTeX workshop files
*.vscode/*

# TeXShop specific
*.texp
*.pdfsync

# TeXstudio specific
*.txs

# Kile specific
*.backup*

# MacOS specific
.DS_Store

# Python virtual environment
scripts/.venv/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg

.env
